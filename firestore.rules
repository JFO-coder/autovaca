rules_version = '2';

// Autovaca Firestore Security Rules
// Test mode: open read/write until April 17, 2026
// Production: read = public, write = authenticated (Juan only)

service cloud.firestore {
  match /databases/{database}/documents {

    // FX rates cache — readable by anyone, writable by authenticated users
    match /fxRates/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Groups — readable by anyone (public transparency), writable by authenticated users
    match /groups/{groupId} {
      allow read: if true;
      allow write: if request.auth != null;

      // Transactions — same rules
      match /transactions/{txnId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Settlements — same rules
      match /settlements/{settlementId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
